# 复制为 .env 供 Docker Compose 做变量替换。
# 应用主配置仍在 config.json；从 config.example.json 复制后填写密钥。

# 服务
# GROK2API_HOST=127.0.0.1
# GROK2API_PORT=8787
# GROK2API_API_KEY=sk-change-me
# GROK2API_APP_KEY=admin-change-me

# Docker 镜像内置前端目录；裸 Go 开发运行可留空（仅 API）
# GROK2API_FRONTEND_STATIC_PATH=/app/frontend/dist

# CLI 上游
# GROK2API_DEFAULT_MODEL=grok-4.5
# GROK2API_CLIENT_VERSION=0.2.93
