# 可选：覆盖 config.json（优先改 config.json）
# 从 config.example.json 复制出 config.json 再填密钥

# 指定配置文件路径
# GROK2API_CONFIG=E:\AokiCore\grok2api\config.json

# 服务
# GROK2API_HOST=127.0.0.1
# GROK2API_PORT=8787
# GROK2API_API_KEY=sk-change-me
# GROK2API_APP_KEY=admin-change-me

# CLI 上游
# GROK2API_DEFAULT_MODEL=grok-4.5
# GROK2API_CLIENT_VERSION=0.2.93
# GROK2API_AUTO_CLIENT_VERSION=true
