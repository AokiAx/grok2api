# Host-only runtime overrides for docker compose on the server.
# Do not commit real secrets into git.

GROK2API_IMAGE=ghcr.io/aokiax/grok2api:latest
GROK2API_PORT=8787

# Side-car host ports (loopback only)
WARP_SOCKS_PORT=40001
PRIVOXY_PORT=40081
FLARESOLVERR_PORT=8192
FLARESOLVERR_LOG_LEVEL=info
TZ=Asia/Shanghai

# Inside docker network DNS names
GROK2API_PROXY=http://privoxy:8118

# Optional WARP+ license
# WARP_LICENSE_KEY=
